  "keyFeatures": [
    "Complete V2 and V3/UTA REST API coverage with TypeScript types",
    "Robust WebSocket clients with automatic reconnection and resubscription",
    "WebSocket API Client for REST-like order placement over WebSockets",
    "Full TypeScript support with strongly-typed requests and responses",
    "HMAC and RSA authentication support",
    "Browser support via webpack bundle",
    "Demo trading environment support",
    "Custom logger and sign function injection",
    "Proxy support via axios",
    "Over 100 end-to-end integration tests"
  ],
